# Atlas Brain local provider config.
# Copy to .atlas-brain.env and fill ATLAS_LLM_API_KEY locally.

export ATLAS_LLM_BASE_URL="https://api.xiaomimimo.com/v1"
export ATLAS_LLM_API_KEY=""
export ATLAS_LLM_MODEL="xiaomi/mimo-v2.5-pro"
export ATLAS_ASR_MODEL="mimo-v2.5-asr"
export ATLAS_TTS_MODEL="mimo-v2.5-tts"
export ATLAS_TTS_VOICE="mimo_default"

# DualEye can stay on AP mode at 192.168.4.1, or use its LAN IP after Wi-Fi pairing.
export ATLAS_DUALEYE_URL="http://192.168.3.60"
export ATLAS_BRIDGE_HOST="0.0.0.0"
export ATLAS_BRIDGE_PORT="8787"
